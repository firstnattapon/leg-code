    "refined_goal": "Step 0 อ่าน immutable snapshot และ latest anchor, Steps 1–17 คำนวณ row เดียว, Step 18 append ด้วย transaction และ UAT Submit อยู่หลัง final เท่านั้น",
    "target_metric": {
      "name": "one-row acceptance ratio",
      "current": 0,
      "target": 1,
      "unit": "ratio",
      "horizon": "ก่อน deploy"
    },
    "success_criteria": [
      "หนึ่ง run append หนึ่ง row",
      "old trade-log reads เป็นศูนย์",
      "retry ไม่สร้างซ้ำและ stale anchor ถูกปฏิเสธ",
      "Production read-only"
    ]
  },
  "step_2_problems": [
    {
      "id": "P1",
      "description": "multi-row history pipeline",
      "gap_value": 40,
      "severity": 5
    },
    {
      "id": "P2",
      "description": "logged-field copying",
      "gap_value": 25,
      "severity": 5
    },
    {
      "id": "P3",
      "description": "missing anchor transaction and safe order boundary",
      "gap_value": 35,
      "severity": 5
    }
  ],
  "step_3_diagnosis": [
    {
      "problem_id": "P1",
      "root_causes": [
        {
          "id": "RC1",
          "cause": "raw history เป็นหน่วย pipeline",
          "why_chain": [
            "Step 0 โหลดหลายแถว",
            "ทุก stage คง row count"
          ],
          "impact_weight": 1,
          "evidence": "legacy len(raw) contract"
        }
      ]
    },
    {
      "problem_id": "P2",
      "root_causes": [
        {
          "id": "RC2",
          "cause": "blocks อ่าน decision fields เก่า",
          "why_chain": [
            "ไม่มี current decision contract",
            "ไม่ใช้ snapshot เป็น source"
          ],
          "impact_weight": 1,
          "evidence": "legacy coalescing blocks"
        }
      ]
    },
    {
      "problem_id": "P3",
      "root_causes": [
        {
          "id": "RC3",
          "cause": "ไม่มี latest pointer/version และ order panel อยู่ก่อน final",
          "why_chain": [
            "retry สร้างซ้ำได้",
            "concurrent run ใช้ anchor เดียวกันได้"
          ],
          "impact_weight": 1,
          "evidence": "legacy Step 18 เป็น export เท่านั้น"
        }
      ]
    }
  ],
  "step_4_design": [
    {
      "id": "S1",
      "targets_root_cause": "RC1",
      "intervention": "one immutable snapshot + one-row stage engine",
      "expected_effect": 40,
      "cost": 10,
      "priority_score": 4,
      "rank": 1
    },
    {
      "id": "S2",
      "targets_root_cause": "RC2",
      "intervention": "calculate DNA, decision and recurrence",
      "expected_effect": 25,
      "cost": 8,
      "priority_score": 3.125,
      "rank": 2
    },
    {
      "id": "S3",
      "targets_root_cause": "RC3",
      "intervention": "transactional Step 18 + post-final UAT gate",
      "expected_effect": 35,
      "cost": 12,
      "priority_score": 2.917,
      "rank": 3
    }
  ],
  "step_5_do_it": {
    "action_plan": [
      {
        "action": "implement snapshot/anchor contracts",
        "owner": "Codex",
        "start": "Phase 1",
        "end": "Phase 2",
        "depends_on": []
      },
      {
        "action": "migrate 17 stages, UI and single file",
        "owner": "Codex",
        "start": "Phase 2",
        "end": "Phase 4",
        "depends_on": [
          "snapshot/anchor contracts"
        ]
      },
      {
        "action": "add transaction, UAT gate, tests and docs",
        "owner": "Codex",
        "start": "Phase 4",
        "end": "Phase 5",
        "depends_on": [
          "one-row engine"
        ]
      }
    ],
    "measurement": {
      "kpis": [
        {
          "name": "row cardinality",
          "formula": "appended_rows/successful_runs",
          "target": 1,
          "frequency": "ทุก test"
        },
        {
          "name": "old history reads",
          "formula": "old_trade_log_reads",
          "target": 0,
          "frequency": "ทุก test"
        },
        {
          "name": "test pass rate",
          "formula": "passed/total",
          "target": 1,
          "frequency": "ทุก commit"
        }
      ],
      "evaluation_equations": [
        {
          "name": "Goal attainment",
          "formula": "A=G_n/G_target",
          "interpret": "A>=1 คือผ่าน"
        },
        {
          "name": "Progress",
          "formula": "P=(G_n-G_0)/(G_target-G_0)",
          "interpret": "สัดส่วนความคืบหน้า"
        },
        {
          "name": "Recurrence",
          "formula": "Rn=FIX_C*ln(Pn/P0); deltaAn=FIX_C*(Pn/Pn-1-1); An=An-1+deltaAn; En=An-Rn",
          "interpret": "ใช้ current snapshot กับ latest anchor"
        }
      ],
      "loop": {
        "control_equation": "e_n = G_target - G_n",
        "convergence_rate": "r_n = |e_n| / |e_{n-1}|",
        "stop_condition": "|e_n| <= epsilon",
        "epsilon": 0,
        "gain_K": 0.5,
        "correction": "u_{n+1} = K * e_n",
        "n_max": 5,
        "escalation_ladder": [
          {
            "if": "r_n < 1",
            "loop_back_to": "step_5",
            "action": "แก้ tests ที่เหลือ"
          },
          {
            "if": "r_n ~ 1",
            "loop_back_to": "step_3",
            "action": "วินิจฉัยใหม่"
          },
          {
            "if": "r_n > 1",
            "loop_back_to": "step_2",
            "action": "ทบทวน problem boundary"
          },
          {
            "if": "still far after n cycles",
            "loop_back_to": "step_1",
            "action": "แบ่ง rollout"
          }
        ]
      }
    }
  },
  "assumptions": [
    "P0 มาจากแถวแรก",
    "Production read-only",
    "final export มี current row เดียว"
  ]
}
